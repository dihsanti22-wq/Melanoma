# ============================================================
# MELANOMA DETECTOR — Environment Variables Template
# Salin file ini menjadi .env.local untuk pengembangan lokal
# ============================================================

# URL publik aplikasi (ganti dengan domain Vercel setelah deploy)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Path model ONNX (relatif terhadap folder /public)
NEXT_PUBLIC_MODEL_PATH=/models/best.onnx

# Confidence threshold default untuk deteksi (0.0 - 1.0)
NEXT_PUBLIC_CONFIDENCE_THRESHOLD=0.25

# IoU threshold untuk Non-Maximum Suppression (0.0 - 1.0)
NEXT_PUBLIC_IOU_THRESHOLD=0.45

# Ukuran input model (piksel)
NEXT_PUBLIC_MODEL_INPUT_SIZE=640

# Mode debug (true = tampilkan log tambahan di console)
NEXT_PUBLIC_DEBUG_MODE=false
