# ────────────────────────────────────────────────────────────────
# .gitignore — Melanoma Detector Web Project
# ────────────────────────────────────────────────────────────────

# ─── Dependencies ────────────────────────────────────────────────
node_modules/
.npm

# ─── Next.js Build Output ────────────────────────────────────────
.next/
out/
build/

# ─── Environment Variables (JANGAN DI-COMMIT) ────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── Model PyTorch (Terlalu Besar untuk Git) ─────────────────────
*.pt
*.pth
models/*.pt
models/*.pth
training/runs/

# ─── Model ONNX (boleh di-commit jika < 100MB, opsional) ─────────
# Uncomment baris di bawah jika model ONNX terlalu besar (>100MB)
# *.onnx
# public/models/*.onnx

# ─── Training Output & Logs ───────────────────────────────────────
training/runs/
training/datasets/
training/__pycache__/
training/.ipynb_checkpoints/
*.ipynb_checkpoints

# ─── Dataset (Jangan Di-commit, Terlalu Besar) ────────────────────
data/
datasets/
*.zip
*.tar.gz

# ─── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.Python
venv/
.venv/
env/

# ─── OS Files ─────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Editor ───────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ─── Vercel ───────────────────────────────────────────────────────
.vercel

# ─── TypeScript ───────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Testing ──────────────────────────────────────────────────────
coverage/
.nyc_output
